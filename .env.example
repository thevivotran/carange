# Copy to .env and fill in values for local development.
# .env is gitignored.
#
# Self-hosting via Docker Compose? You don't need this file — environment
# variables are set directly in docker-compose.yml.
# See the "Self-Hosting" section in README.md.

# Local PostgreSQL (matches docker-compose.dev.yml — `docker compose -f docker-compose.dev.yml up`)
DATABASE_URL=postgresql://carange:carange@localhost:5432/carange

# Where uploaded OCR screenshots are stored (optional for local dev)
# UPLOAD_DIR=uploads

# AI budget insights / Pulse — point at a self-hosted LLM (optional for local dev)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# Telegram notifications (optional for local dev)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Email worker (optional for local dev)
# IMAP_HOST=
# IMAP_USER=
# IMAP_PASS=
